{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/rank.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/rank",
      "dest": "/api/rank.py"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
